# Local development defaults — works out of the box with `docker compose up -d`.
# Copy to .env or just run `npm run dev` (Next.js loads .env.development automatically).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smashladder"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/smashladder"
DATABASE_URL_POOLED="postgresql://postgres:postgres@localhost:5432/smashladder"
AUTH_SECRET="dev-secret-do-not-use-in-production"
