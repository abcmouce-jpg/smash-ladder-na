# --- Database (Neon) ---
# Neon プロジェクト作成後、Connection Details から取得する。
# DATABASE_URL / DIRECT_URL: 非pooled(直接)接続文字列。prisma.config.ts が
#   `prisma migrate` / `generate` 用に使う。ホスト名に "-pooler" が付かない方。
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# DATABASE_URL_POOLED: pooled connection string (PgBouncer経由、ホスト名に "-pooler" が付く方)。
#   src/lib/db.ts のランタイムPrismaクライアントはこちらを使う。サーバーレス環境では
#   リクエストごとに新しい直接接続を張るとNeonの接続数上限をすぐ使い切るため必須。
DATABASE_URL_POOLED="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# --- Auth.js (NextAuth) ---
# `npx auth secret` または `openssl rand -base64 32` で生成する。
AUTH_SECRET=""

# Discord Developer Portal (https://discord.com/developers/applications) で作成したアプリケーションの値。
# OAuth2 > Redirects に http://localhost:3000/api/auth/callback/discord を追加しておく。
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# --- Cron finalizer (Sprint 2以降で使用) ---
# 外部スケジューラ(cron-job.org / GitHub Actions)から /api/cron/finalize を叩く際の共有シークレット。
CRON_SECRET=""

# --- Launch region lock (Sprint 25、スモールスタート用) ---
# 設定すると、この値と完全一致するregionを設定したユーザーのみロビー/フリーバトルに参加可能になる。
# 展開範囲を広げる際は空にする。値は src/lib/regions.ts の NA_REGIONS のいずれかと一致させること。
LAUNCH_REGION_LOCK="NA East"
