# --- Database (Neon) ---
# After creating a Neon project, get these from Connection Details.
# DATABASE_URL / DIRECT_URL: unpooled (direct) connection strings. Used by
#   prisma.config.ts for `prisma migrate` / `generate`. The hostname does
#   NOT have "-pooler" in it.
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# DATABASE_URL_POOLED: pooled connection string (via PgBouncer, hostname
#   HAS "-pooler" in it). The runtime Prisma client in src/lib/db.ts uses
#   this one — required because opening a new direct connection per request
#   in a serverless environment would quickly exhaust Neon's connection limit.
DATABASE_URL_POOLED="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# --- Auth.js (NextAuth) ---
# Generate with `npx auth secret` or `openssl rand -base64 32`.
AUTH_SECRET=""

# From the application you create in the Discord Developer Portal
# (https://discord.com/developers/applications). Add
# http://localhost:3000/api/auth/callback/discord under OAuth2 > Redirects.
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# --- Cron finalizer ---
# Shared secret used when an external scheduler (cron-job.org / GitHub
# Actions) calls /api/cron/finalize.
CRON_SECRET=""

# --- Launch region lock (small-start rollout) ---
# When set, only users whose region exactly matches this value can join the
# lobby/free battle. Leave empty to open matchmaking up more broadly. The
# value must match one of the entries in NA_REGIONS in src/lib/regions.ts.
LAUNCH_REGION_LOCK="NA East"

# --- Discord bot notifications ---
# Get this from the Discord Developer Portal → your application → Bot tab →
# Reset Token. If unset, notifications are silently skipped (no effect on
# any other feature).
# Note: if the bot and the user don't share a Discord server, DM delivery
# fails per Discord's own restriction (silently — no effect on app
# behavior). To actually deliver notifications, invite this bot to the
# community Discord server.
DISCORD_BOT_TOKEN=""

# --- start.gg integration (read-only) ---
# API token from the start.gg Developer Portal
# (https://start.gg/admin/profile/developer). If unset, live enrichment from
# start.gg (entrant count, final standings) is skipped and only the existing
# "View bracket on start.gg" link is shown (no effect on any other feature).
# Only attempted when the tournament URL is in the
# .../tournament/<slug>/event/<slug> form (a single event) — a link to the
# whole tournament is ambiguous about which event to show.
STARTGG_API_TOKEN=""

# --- Ad monetization / Google AdSense ---
# Publisher ID (ca-pub-xxxxxxxxxxxxxxxx format) from your site's settings
# once your AdSense account (https://adsense.google.com) is approved. If
# unset, no ads are shown anywhere and ads.txt returns empty (no effect on
# any other feature).
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""

# Only active if the above is set. Set the slot ID from AdSense's "ad unit"
# creation screen when rolling out a manual ad unit on a given page. Pages
# left unset show no ad (rollout is per-page). Deliberately no ad units on
# the lobby or an active match — that experience stays ad-free.
NEXT_PUBLIC_ADSENSE_SLOT_LEADERBOARD=""
NEXT_PUBLIC_ADSENSE_SLOT_TOURNAMENTS=""
NEXT_PUBLIC_ADSENSE_SLOT_CHARACTERS=""
NEXT_PUBLIC_ADSENSE_SLOT_FREE_BATTLE=""

# --- Error monitoring (Sentry) ---
# After creating a project at sentry.io, get this from Settings > Projects >
# (project name) > Client Keys (DSN). Set the same DSN value for both the
# server/edge and client variables (the NEXT_PUBLIC_ one is exposed to the
# browser, but a DSN is meant to be public, so that's fine).
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# --- Season management restriction (temporary measure) ---
# Restricts who can end a season (which resets everyone's rating) to a
# single user. Unless the signed-in user's cuid matches this value, the "End
# season" button on /admin/seasons won't show even for MOD/ADMIN, and the
# server rejects the action too. If unset, the original behavior (any
# MOD/ADMIN can do it) applies.
SEASON_MANAGER_USER_ID=""
