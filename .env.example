# --- Database (Neon) ---
# Neon プロジェクト作成後、Connection Details から取得する。
# DATABASE_URL: pooled connection string (PgBouncer経由)。Next.js実行時のPrismaクライアントが使う想定。
#   Sprint 1でNeon driver adapter(@prisma/adapter-neon)を使って接続する際にこちらを渡す。
# 現時点(Sprint 0)では prisma.config.ts が DATABASE_URL を migrate/generate 用にも共用しているため、
# ローカル開発中に `prisma migrate dev` を頻繁に叩く場合は DIRECT_URL (非pooled) の値をここに設定しておくと安定する。
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# DIRECT_URL: 非pooled(直接)接続文字列。将来 prisma.config.ts のマイグレーション用設定を分離する場合に使用。
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# --- Auth.js (NextAuth) ---
# `npx auth secret` または `openssl rand -base64 32` で生成する。
AUTH_SECRET=""

# Discord Developer Portal (https://discord.com/developers/applications) で作成したアプリケーションの値。
# OAuth2 > Redirects に http://localhost:3000/api/auth/callback/discord を追加しておく。
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# --- Cron finalizer (Sprint 2以降で使用) ---
# 外部スケジューラ(cron-job.org / GitHub Actions)から /api/cron/finalize を叩く際の共有シークレット。
CRON_SECRET=""
