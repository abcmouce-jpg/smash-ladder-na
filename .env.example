# --- Database (Neon) ---
# Neon プロジェクト作成後、Connection Details から取得する。
# DATABASE_URL / DIRECT_URL: 非pooled(直接)接続文字列。prisma.config.ts が
#   `prisma migrate` / `generate` 用に使う。ホスト名に "-pooler" が付かない方。
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# DATABASE_URL_POOLED: pooled connection string (PgBouncer経由、ホスト名に "-pooler" が付く方)。
#   src/lib/db.ts のランタイムPrismaクライアントはこちらを使う。サーバーレス環境では
#   リクエストごとに新しい直接接続を張るとNeonの接続数上限をすぐ使い切るため必須。
DATABASE_URL_POOLED="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# --- Auth.js (NextAuth) ---
# `npx auth secret` または `openssl rand -base64 32` で生成する。
AUTH_SECRET=""

# Discord Developer Portal (https://discord.com/developers/applications) で作成したアプリケーションの値。
# OAuth2 > Redirects に http://localhost:3000/api/auth/callback/discord を追加しておく。
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# --- Cron finalizer (Sprint 2以降で使用) ---
# 外部スケジューラ(cron-job.org / GitHub Actions)から /api/cron/finalize を叩く際の共有シークレット。
CRON_SECRET=""

# --- Launch region lock (Sprint 25、スモールスタート用) ---
# 設定すると、この値と完全一致するregionを設定したユーザーのみロビー/フリーバトルに参加可能になる。
# 展開範囲を広げる際は空にする。値は src/lib/regions.ts の NA_REGIONS のいずれかと一致させること。
LAUNCH_REGION_LOCK="NA East"

# --- Discord bot notifications (Sprint 28) ---
# Discord Developer Portal → 対象アプリケーション → Bot タブ → Reset Token で取得。
# 未設定の場合、通知は静かにスキップされる(他の機能には影響しない)。
# 注意: BotとユーザーがどこかのDiscordサーバーを共有していない場合、DM送信はDiscord側の
# 仕様により失敗する(黙って握りつぶされるだけで、アプリの動作には影響しない)。
# 実際に通知を届けるには、コミュニティのDiscordサーバーにこのBotを招待しておく必要がある。
DISCORD_BOT_TOKEN=""

# --- start.gg 連携 (読み取り専用) ---
# start.gg Developer Portal (https://start.gg/admin/profile/developer) で取得したAPIトークン。
# 未設定の場合、start.ggからの追加情報(参加者数・最終順位)は表示されず、既存の
# 「View bracket on start.gg」リンクのみが表示される(他の機能には影響しない)。
# トーナメントのURLが .../tournament/<slug>/event/<slug> の形(単一イベントを指す形)の
# 場合のみ取得を試みる — トーナメント全体へのリンクだとどのイベントか一意に決まらないため。
STARTGG_API_TOKEN=""

# --- Ad monetization / Google AdSense (Sprint 26) ---
# AdSenseアカウント (https://adsense.google.com) 承認後、サイト設定から取得する
# パブリッシャーID (ca-pub-xxxxxxxxxxxxxxxx形式)。未設定の場合、広告は一切表示されず
# ads.txt も空を返す(他の機能には影響しない)。
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""

# 上記が設定済みの場合のみ有効。各ページに手動広告ユニットを出す際、AdSenseの
# 「広告ユニット」作成画面で取得したスロットIDを設定する。未設定のページには
# 広告は表示されない(ページ単位で個別にロールアウト可能)。
# ロビーや対戦中の画面には意図的に広告を置いていない — 対戦中の体験を優先するため。
NEXT_PUBLIC_ADSENSE_SLOT_LEADERBOARD=""
NEXT_PUBLIC_ADSENSE_SLOT_TOURNAMENTS=""
NEXT_PUBLIC_ADSENSE_SLOT_CHARACTERS=""
NEXT_PUBLIC_ADSENSE_SLOT_FREE_BATTLE=""

# --- Error monitoring (Sentry) ---
# sentry.io でプロジェクト作成後、Settings > Projects > (プロジェクト名) > Client Keys (DSN) で取得。
# サーバー/エッジ用とクライアント用で同じDSN値を両方の変数に設定する
# (NEXT_PUBLIC_ 側はブラウザに露出するが、DSNはそもそも公開される前提の値なので問題ない)。
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
